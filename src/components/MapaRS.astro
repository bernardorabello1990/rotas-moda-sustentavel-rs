---
import regioes from '../data/regioes.json';
import mapa from '../data/mapa-rs.json';

interface Props { rotulos?: boolean; fio?: boolean }
const { rotulos = true, fio = true } = Astro.props;

const cor: Record<string, string> = Object.fromEntries(regioes.map((r) => [r.id, r.cor]));
const m = mapa.marcadores as Record<string, [number, number]>;

const ROTULOS: Record<string, string> = {
  serra: 'Serra Gaúcha',
  campanha: 'Campanha',
  sinos: 'Vale dos Sinos',
  metropolitana: 'Porto Alegre',
};
const GUIA: Record<string, { lx: number; ly: number; anchor: 'end' | 'middle'; tx: number; ty: number }> = {
  serra: { lx: 690, ly: 262, anchor: 'end', tx: 676, ty: 266 },
  sinos: { lx: 690, ly: 372, anchor: 'end', tx: 676, ty: 376 },
  metropolitana: { lx: 690, ly: 462, anchor: 'end', tx: 676, ty: 466 },
  campanha: { lx: 386, ly: 648, anchor: 'middle', tx: 386, ty: 686 },
};

// Fio da rota: costura passando pelas regiões (Catmull-Rom -> curva suave)
const rota = ['campanha', 'metropolitana', 'sinos', 'serra'].map((id) => m[id]).filter(Boolean);
function catmullRom(pts: number[][]): string {
  if (pts.length < 2) return '';
  let d = `M${pts[0][0].toFixed(1)},${pts[0][1].toFixed(1)}`;
  for (let i = 0; i < pts.length - 1; i++) {
    const p0 = pts[i - 1] ?? pts[i];
    const p1 = pts[i];
    const p2 = pts[i + 1];
    const p3 = pts[i + 2] ?? p2;
    const c1x = p1[0] + (p2[0] - p0[0]) / 6;
    const c1y = p1[1] + (p2[1] - p0[1]) / 6;
    const c2x = p2[0] - (p3[0] - p1[0]) / 6;
    const c2y = p2[1] - (p3[1] - p1[1]) / 6;
    d += ` C${c1x.toFixed(1)},${c1y.toFixed(1)} ${c2x.toFixed(1)},${c2y.toFixed(1)} ${p2[0].toFixed(1)},${p2[1].toFixed(1)}`;
  }
  return d;
}
const fioPath = catmullRom(rota);
const idsRotulo = Object.keys(ROTULOS).filter((id) => m[id]);
---
<svg
  viewBox={mapa.viewBox}
  role="img"
  aria-label="Mapa bordado do Rio Grande do Sul destacando as quatro regiões da pesquisa: Serra Gaúcha, Região da Campanha, Vale dos Sinos e Região Metropolitana de Porto Alegre"
  class="mapa"
  class:list={[{ 'mapa--anima': fio }]}
>
  <defs>
    <pattern id="trama" width="9" height="9" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="0" y2="9" stroke="var(--cor-apoio)" stroke-width="0.8" opacity="0.18" />
      <line x1="0" y1="0" x2="9" y2="0" stroke="var(--cor-apoio)" stroke-width="0.8" opacity="0.10" />
    </pattern>
  </defs>

  <!-- Tecido do estado: fundo + trama de linho -->
  <path d={mapa.path} class="mapa__tecido" />
  <path d={mapa.path} class="mapa__trama" />
  <!-- Contorno bordado em ponto-corrido -->
  <path d={mapa.path} class="mapa__costura" />

  <!-- Fio da rota, que se costura entre as regiões -->
  {fio && <path d={fioPath} class="mapa__fio" pathLength="1" />}

  <!-- Nós de ponto-cruz por região (× marca o lugar) -->
  {idsRotulo.map((id, i) => {
    const [x, y] = m[id];
    const t = 12;
    return (
      <g class="mapa__no" style={`--cor-no:${cor[id]};--i:${i}`}>
        <circle cx={x} cy={y} r="17" class="mapa__halo" />
        <line x1={x - t} y1={y - t} x2={x + t} y2={y + t} class="mapa__ponto" />
        <line x1={x - t} y1={y + t} x2={x + t} y2={y - t} class="mapa__ponto" />
      </g>
    );
  })}

  <!-- Rótulos com linha-guia pontilhada -->
  {rotulos && idsRotulo.map((id) => {
    const [x, y] = m[id];
    const g = GUIA[id];
    return (
      <g class="mapa__rotulo-g">
        <polyline points={`${x},${y} ${g.lx},${g.ly}`} class="mapa__guia" />
        <text x={g.tx} y={g.ty} text-anchor={g.anchor} class="mapa__rotulo">{ROTULOS[id]}</text>
      </g>
    );
  })}
</svg>

<style>
  .mapa { width: 100%; height: auto; overflow: visible; }

  .mapa__tecido { fill: var(--cor-fundo-alt); opacity: 0.55; }
  .mapa__trama { fill: url(#trama); stroke: none; }

  .mapa__costura {
    fill: none;
    stroke: var(--cor-acao);
    stroke-width: 4.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 11 9; /* ponto-corrido grosso e visível */
    opacity: 0.92;
  }

  .mapa__fio {
    fill: none;
    stroke: var(--cor-texto);
    stroke-width: 3.4;
    stroke-linecap: round;
    opacity: 0.85;
  }

  .mapa__halo { fill: var(--cor-no); opacity: 0.16; }
  .mapa__ponto {
    stroke: var(--cor-no);
    stroke-width: 4;
    stroke-linecap: round;
  }

  .mapa__guia {
    fill: none;
    stroke: var(--cor-texto-2);
    stroke-width: 1;
    stroke-dasharray: 1 5;
    stroke-linecap: round;
    opacity: 0.55;
  }
  .mapa__rotulo {
    font-family: var(--fonte-titulo);
    font-size: 28px;
    font-style: italic;
    fill: var(--cor-texto);
  }

  /* Animação: o fio se desenha, os nós surgem em sequência */
  .mapa--anima .mapa__fio {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: costurar 2.4s ease-in-out 0.4s forwards;
  }
  .mapa--anima .mapa__no {
    opacity: 0;
    animation: bordar 0.5s ease-out forwards;
    animation-delay: calc(1.7s + var(--i) * 0.4s);
    transform-box: fill-box;
    transform-origin: center;
  }
  @keyframes costurar { to { stroke-dashoffset: 0; } }
  @keyframes bordar {
    from { opacity: 0; transform: scale(0.4); }
    to { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mapa--anima .mapa__fio { animation: none; stroke-dasharray: none; stroke-dashoffset: 0; }
    .mapa--anima .mapa__no { animation: none; opacity: 1; }
  }
</style>
