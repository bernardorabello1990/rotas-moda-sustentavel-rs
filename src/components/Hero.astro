---
import { site } from '../data/site.ts';
---
<section id="hero" class="heroi">
  <div class="container heroi__centro">
    <h1 class="sr-only">Rotas da Moda Sustentável RS — mapeamento cultural da moda sustentável no Rio Grande do Sul</h1>
    <span class="tag heroi__olho">Pesquisa cultural · <span class="nao-quebra">Rio Grande do Sul</span></span>
    <div class="heroi__peca">
      <img
        src="/imagens/hero/hero-mapa.webp"
        width="1500" height="1120"
        alt="Mapa bordado do Rio Grande do Sul feito de tecidos e retalhos, com as quatro regiões da pesquisa costuradas — Serra Gaúcha, Vale dos Sinos, Campanha e Porto Alegre — e uma rota de linha vermelha ligando-as, cercado por elementos de costura."
      />
    </div>
    <p class="heroi__texto">{site.descricao}</p>
    <div class="heroi__acoes">
      <a class="botao" href="#contato">Seja parceiro</a>
      <a class="botao botao--fantasma" href="#o-projeto">Conheça o projeto</a>
    </div>
  </div>
</section>

<style>
  .heroi { padding-block: 1.75rem 2.75rem; }
  @media (min-width: 820px) { .heroi { padding-block: 2rem 3.25rem; } }

  .heroi__centro {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .heroi__peca {
    max-width: 760px;
    width: 100%;
    margin: 0.25rem 0 1.4rem;
    display: flex;
    justify-content: center;
  }
  .heroi__peca img {
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 56vh;
    border-radius: 12px;
    box-shadow: 0 26px 55px -26px color-mix(in srgb, var(--cor-texto) 72%, transparent);
    animation: heroi-entra 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  @media (min-width: 820px) {
    .heroi__peca img { max-height: 60vh; }
  }
  @keyframes heroi-entra {
    from { opacity: 0; transform: translateY(18px) scale(0.985); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .heroi__peca img { animation: none; }
  }
  .heroi__texto {
    color: var(--cor-texto-2);
    max-width: 40rem;
    font-size: 1.18rem;
  }
  .heroi__acoes {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.6rem;
  }

  .nao-quebra { white-space: nowrap; }

  @media (max-width: 767px) {
    .heroi__olho {
      display: block;
      font-size: 0.66rem;
      letter-spacing: 0.16em;
      line-height: 1.5;
      text-wrap: balance;
    }
    .heroi__olho::before { display: none; }
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
</style>
