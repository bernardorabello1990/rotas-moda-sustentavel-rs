---
import regioes from '../data/regioes.json';

const cor: Record<string, string> = Object.fromEntries(regioes.map((r) => [r.id, r.cor]));

// Uma folha bordada: duas curvas espelhadas entre base e ponta
function folha(bx: number, by: number, tx: number, ty: number) {
  const mx = (bx + tx) / 2, my = (by + ty) / 2;
  const dx = tx - bx, dy = ty - by;
  const len = Math.hypot(dx, dy) || 1;
  const px = -dy / len, py = dx / len;
  const w = len * 0.34;
  const c1x = mx + px * w, c1y = my + py * w;
  const c2x = mx - px * w, c2y = my - py * w;
  return {
    contorno: `M${bx},${by} Q${c1x.toFixed(1)},${c1y.toFixed(1)} ${tx},${ty} Q${c2x.toFixed(1)},${c2y.toFixed(1)} ${bx},${by} Z`,
    veia: `M${bx},${by} L${tx},${ty}`,
  };
}

const folhas = [
  { ...folha(150, 214, 104, 206), cor: cor.serra },
  { ...folha(150, 189, 198, 182), cor: cor.campanha },
  { ...folha(150, 165, 106, 152), cor: cor.sinos },
  { ...folha(150, 141, 196, 133), cor: cor.metropolitana },
];
---
<svg viewBox="0 0 300 330" class="bastidor" role="img"
  aria-label="Ilustração de um bastidor de bordado com um raminho de folhas nas cores das quatro regiões da pesquisa, agulha e linha">
  <defs>
    <pattern id="trama-b" width="8" height="8" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="0" y2="8" stroke="var(--cor-apoio)" stroke-width="0.7" opacity="0.16" />
      <line x1="0" y1="0" x2="8" y2="0" stroke="var(--cor-apoio)" stroke-width="0.7" opacity="0.09" />
    </pattern>
  </defs>

  <!-- Tecido dentro do aro -->
  <circle cx="150" cy="172" r="118" class="bast__tecido" />
  <circle cx="150" cy="172" r="118" fill="url(#trama-b)" />

  <!-- Raminho bordado -->
  <g class="bast__bordado">
    <path d="M150,246 C146,215 154,180 150,150 C147,128 151,116 150,108" class="bast__caule" />
    {folhas.map((f) => (
      <g>
        <path d={f.contorno} fill={f.cor} opacity="0.9" />
        <path d={f.veia} stroke="color-mix(in srgb, var(--cor-fundo) 55%, transparent)" stroke-width="1.4" fill="none" stroke-dasharray="2 3" stroke-linecap="round" />
      </g>
    ))}
    <!-- Botão de flor no topo: ponto-cruz -->
    <g class="bast__flor">
      <line x1="143" y1="101" x2="157" y2="115" /><line x1="143" y1="115" x2="157" y2="101" />
      <line x1="150" y1="97" x2="150" y2="119" /><line x1="139" y1="108" x2="161" y2="108" />
    </g>
    <circle cx="150" cy="108" r="3.4" fill="var(--cor-acao)" />
  </g>

  <!-- Agulha e linha entrando no tecido, na base do caule -->
  <g class="bast__agulha">
    <path d="M150,246 C180,262 206,266 226,250" class="bast__linha" />
    <g transform="translate(226 250) rotate(28)">
      <polygon points="0,-6 -2.4,44 2.4,44" />
      <rect x="-2.4" y="44" width="4.8" height="15" rx="2.4" />
      <ellipse cx="0" cy="52" rx="1.2" ry="4" class="bast__fenda" />
    </g>
  </g>

  <!-- Aro de madeira -->
  <circle cx="150" cy="172" r="118" class="bast__aro-interno" />
  <circle cx="150" cy="172" r="126" class="bast__aro" />
  <circle cx="150" cy="172" r="132" class="bast__aro-externo" />
  <!-- Fecho metálico no topo -->
  <rect x="138" y="34" width="24" height="20" rx="4" class="bast__fecho" />
  <circle cx="150" cy="44" r="3.2" class="bast__parafuso" />
</svg>

<style>
  .bastidor { width: 100%; height: auto; overflow: visible; }
  .bast__tecido { fill: var(--cor-fundo); }

  .bast__caule {
    fill: none;
    stroke: var(--cor-apoio);
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-dasharray: 5 5;
  }
  .bast__flor line {
    stroke: var(--cor-acento);
    stroke-width: 3;
    stroke-linecap: round;
  }

  .bast__linha { fill: none; stroke: var(--cor-texto); stroke-width: 2.4; stroke-linecap: round; opacity: 0.85; }
  .bast__agulha polygon, .bast__agulha rect { fill: var(--cor-texto); }
  .bast__fenda { fill: var(--cor-fundo); }

  .bast__aro { fill: none; stroke: var(--cor-apoio); stroke-width: 12; }
  .bast__aro-externo { fill: none; stroke: color-mix(in srgb, var(--cor-texto) 35%, var(--cor-apoio)); stroke-width: 1.5; }
  .bast__aro-interno { fill: none; stroke: color-mix(in srgb, var(--cor-texto) 35%, var(--cor-apoio)); stroke-width: 1.5; }
  .bast__fecho { fill: var(--cor-apoio); stroke: color-mix(in srgb, var(--cor-texto) 40%, var(--cor-apoio)); stroke-width: 1.2; }
  .bast__parafuso { fill: color-mix(in srgb, var(--cor-texto) 45%, var(--cor-apoio)); }
</style>
